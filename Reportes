export async function getCuadroComparativo(referencia: string) {
  const res = await fetch('http://localhost:3000/auraquantic/cuadrocomparativo', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      referencia,
    }),
  });

  if (!res.ok) {
    throw new Error('Error en la petición');
  }

  return res.json();
}
