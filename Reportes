const handleChange =
  (key: keyof FormState) =>
  (
    event: ChangeEvent<
      HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
    >
  ) => {
    const { value } = event.target;

    setForm((previous) => ({
      ...previous,
      [key]:
        key === "eventType"
          ? (value as EventType)
          : value,
    }));
  };