export async function getCuadroComparativo(referencia: string) {
  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/auraquantic/cuadrocomparativo`,
    {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        referencia,
      }),
    }
  );

  if (!res.ok) {
    throw new Error('Error en la petición');
  }

  return res.json();
}