let fillCollor;

if (R === 0 || R === 1) {
  // ENCABEZADOS
  if (C < 4) {
    // Nombre, Cantidad, Unidad, Descripción
    fillCollor = '0F243E'; // azul oscuro EXACTO de la web
  } else {
    // Proveedores
    const proveedorIndex = Math.floor((C - 4) / 12);
    fillCollor = hexToExcel(getColorProveedor(proveedorIndex));
  }

} else {
  // FILAS (como en la web)
  if (C < 4) {
    // columnas fijas
    fillCollor = hexToExcel(getColorCeldas(R - 2));
  } else {
    // proveedores
    fillCollor = hexToExcel(getColorCeldas(R - 2));
  }
}