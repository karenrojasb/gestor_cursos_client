"use client";

import { useEffect, useMemo, useState, type ChangeEvent, type FormEvent, type MouseEvent } from "react";
import { FaCalendarAlt, FaDoorOpen, FaMapMarkerAlt, FaRegTimesCircle, FaUserTie } from "react-icons/fa";
import { FiFileText } from "react-icons/fi";
import {
  EVENT_TYPE_OPTIONS,
  EventType,
} from "@/constants/eventType";

import type { CreateEventDto } from "@/types/events";

interface CreateEventModalProps {
  isOpen: boolean;
  onClose: () => void;
  onCreate: (payload: CreateEventDto) => Promise<void> | void;
  isSubmitting?: boolean;
  submissionError?: string | null;
}


type eventTypeValue = EventType;


interface FormState {
  name: string;
  description: string;
  type: string;
  startDate: string;
  endDate: string;
  organizer: string;
  eventType: eventTypeValue;
  location: string;
  
}

const EMPTY_FORM: FormState = {
  name: "",
  description: "",
  type: "",
  startDate: "",
  endDate: "",
  organizer: "",
  location: "",  
};

const CreateEventModal = ({
  isOpen,
  onClose,
  onCreate,
  isSubmitting = false,
  submissionError = null,
}: CreateEventModalProps) => {
  const [form, setForm] = useState<FormState>(EMPTY_FORM);
  const [validationError, setValidationError] = useState<string | null>(null);

  useEffect(() => {
    if (isOpen) {
      setForm(EMPTY_FORM);
      setValidationError(null);
    }
  }, [isOpen]);

  const isSubmittingDisabled = useMemo(() => {
    return (
      !form.name.trim() ||
      !form.type.trim() ||
      !form.startDate ||
      !form.endDate ||
      !form.organizer.trim() ||
      !form.location.trim()
    );
  }, [form]);

  const handleChange = (key: keyof FormState) => ( event: ChangeEvent<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>
  ) => {const { value } = event.target;
    setForm((previous) => ({...previous,[key]:
        key === "eventType"
          ? (value as EventType)
          : value,
    }));
  };

  const handleOverlayClick = (event: MouseEvent<HTMLDivElement>) => {
    if (event.target === event.currentTarget && !isSubmitting) {
      onClose();
    }
  };

  const handleSubmit = async (event: FormEvent<HTMLFormElement>) => {
    event.preventDefault();

    const trimmedName = form.name.trim();
    const trimmedType = form.type.trim();
    const trimmedOrganizer = form.organizer.trim();
    const trimmedLocation = form.location.trim();

    if (!trimmedName || !trimmedType || !trimmedOrganizer || !trimmedLocation || !form.startDate || !form.endDate) {
      setValidationError("Por favor completa los campos obligatorios marcados con *.");
      return;
    }

    const startsAt = new Date(form.startDate);
    const endsAt = new Date(form.endDate);

    if (Number.isNaN(startsAt.valueOf()) || Number.isNaN(endsAt.valueOf())) {
      setValidationError("Revisa las fechas ingresadas, no pudimos procesarlas.");
      return;
    }

    if (endsAt < startsAt) {
      setValidationError("La fecha de finalización debe ser posterior a la fecha de inicio.");
      return;
    }

    const payload: CreateEventDto = {
      name: trimmedName,
      description: form.description.trim() || undefined,
      type: trimmedType,
      startDate: startsAt.toISOString(),
      endDate: endsAt.toISOString(),
      organizer: trimmedOrganizer,
      location: trimmedLocation,
    };

    setValidationError(null);
    await onCreate(payload);
  };

  if (!isOpen) {
    return null;
  }

  return (
    <div
      className="fixed inset-0 z-30 flex items-center justify-center bg-black/40 px-4"
  role="dialog"
  aria-modal="true"
  onClick={handleOverlayClick}
    >
      <div className="relative w-full max-w-2xl rounded-2xl bg-white p-6 shadow-2xl" style={{ fontFamily: "var(--font-montserrat), Arial, Helvetica, sans-serif" }}>
        <button
          type="button"
          onClick={onClose}
          className="absolute right-4 top-4 text-gray-400 transition hover:text-red-600"
          aria-label="Cerrar modal"
        >
          <FaRegTimesCircle className="h-6 w-6" />
        </button>

        <header className="mb-6">
          <h2 className="text-2xl font-semibold text-gray-900">Crear nuevo evento</h2>
          <p className="mt-1 text-sm text-gray-500">
            Completa la información para registrar un evento académico.
          </p>
        </header>

        <form className="space-y-5" onSubmit={handleSubmit}>
          <div className="grid gap-4 md:grid-cols-2">
            <label className="flex flex-col gap-1 text-sm text-gray-700">
              <span className="flex items-center gap-2 font-medium">
                <FiFileText className="h-4 w-4 text-red-600" />
                Nombre del evento*
              </span>
              <input
                type="text"
                value={form.name}
                onChange={handleChange("name")}
                className="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 focus:border-red-600 focus:outline-none focus:ring-1 focus:ring-red-600"
                placeholder="Feria de proyectos"
                required
              />
            </label>

            <label className="md:col-span-1 flex flex-col gap-2 text-sm text-gray-700">
                    <span className="font-medium">Programa de interés</span>
                     <select
                      value={form.eventType}
                      onChange={handleChange("eventType")}
                      className="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 focus:border-red-600 focus:outline-none focus:ring-1 focus:ring-red-600"
                       >
                      <option value="">Selecciona un programa</option>
                      {EVENT_TYPE_OPTIONS.map((option) => (
                             <option key={option} value={option}>
                                {option}
                           </option>
                      ))}
                 </select>
            </label>

            <label className="flex flex-col gap-1 text-sm text-gray-700 md:col-span-2">
              <span className="flex items-center gap-2 font-medium">
                <FiFileText className="h-4 w-4 text-red-600" />
                Descripción
              </span>
              <textarea
                value={form.description}
                onChange={handleChange("description")}
                rows={3}
                className="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 focus:border-red-600 focus:outline-none focus:ring-1 focus:ring-red-600"
                placeholder="Comparte una breve descripción del evento"
              />
            </label>
          </div>

          <div className="grid gap-4 md:grid-cols-2">
            <label className="flex flex-col gap-1 text-sm text-gray-700">
              <span className="flex items-center gap-2 font-medium">
                <FaCalendarAlt className="h-4 w-4 text-red-600" />
                Fecha y hora de inicio*
              </span>
              <input
                type="datetime-local"
                value={form.startDate}
                onChange={handleChange("startDate")}
                className="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 focus:border-red-600 focus:outline-none focus:ring-1 focus:ring-red-600"
                required
              />
            </label>

            <label className="flex flex-col gap-1 text-sm text-gray-700">
              <span className="flex items-center gap-2 font-medium">
                <FaCalendarAlt className="h-4 w-4 text-red-600" />
                Fecha y hora de finalización*
              </span>
              <input
                type="datetime-local"
                value={form.endDate}
                onChange={handleChange("endDate")}
                className="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 focus:border-red-600 focus:outline-none focus:ring-1 focus:ring-red-600"
                required
              />
            </label>

            <label className="flex flex-col gap-1 text-sm text-gray-700">
              <span className="flex items-center gap-2 font-medium">
                <FaUserTie className="h-4 w-4 text-red-600" />
                Organizador principal*
              </span>
              <input
                type="text"
                value={form.organizer}
                onChange={handleChange("organizer")}
                className="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 focus:border-red-600 focus:outline-none focus:ring-1 focus:ring-red-600"
                placeholder="Dirección de bienestar universitario"
                required
              />
            </label>

            <label className="flex flex-col gap-1 text-sm text-gray-700">
              <span className="flex items-center gap-2 font-medium">
                <FaMapMarkerAlt className="h-4 w-4 text-red-600" />
                Ubicación*
              </span>
              <input
                type="text"
                value={form.location}
                onChange={handleChange("location")}
                className="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 focus:border-red-600 focus:outline-none focus:ring-1 focus:ring-red-600"
                placeholder="Auditorio principal"
                required
              />
            </label>
          </div>

          {validationError ? (
            <p className="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">{validationError}</p>
          ) : null}

          {submissionError ? (
            <p className="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">{submissionError}</p>
          ) : null}

          <div className="flex flex-col gap-3 sm:flex-row sm:justify-end">
            <button
              type="button"
              onClick={onClose}
              disabled={isSubmitting}
              className="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-70"
            >
              Cancelar
            </button>
            <button
              type="submit"
              disabled={isSubmittingDisabled || isSubmitting}
              className="rounded-lg bg-red-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-800 disabled:cursor-not-allowed disabled:bg-gray-300"
            >
              {isSubmitting ? "Creando..." : "Crear evento"}
            </button>
          </div>
        </form>
      </div>
    </div>
  );
};

export default CreateEventModal;
