export async function obtenerCuadroComparativo(referencia: string) {
  const res = await fetch(`${process.env.NEXT_PUBLIC_API_URL}/cuadro-comparativo`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ referencia })
  });

  if (!res.ok) {
    throw new Error('Error al obtener los datos');
  }

  return res.json();
}





import { useState } from 'react';
import { obtenerCuadroComparativo } from '../services/cuadroComparativo';

export default function CuadroComparativoPage() {
  const [referencia, setReferencia] = useState('');
  const [datos, setDatos] = useState<any>(null);
  const [loading, setLoading] = useState(false);

  const handleBuscar = async () => {
    setLoading(true);
    try {
      const res = await obtenerCuadroComparativo(referencia);
      setDatos(res);
    } catch (e) {
      console.error(e);
      alert('Error al consultar los datos');
    }
    setLoading(false);
  };

  return (
    <div>
      <h1>Cuadro Comparativo</h1>
      <input
        type="text"
        value={referencia}
        onChange={(e) => setReferencia(e.target.value)}
        placeholder="Ingrese referencia"
      />
      <button onClick={handleBuscar} disabled={loading}>
        {loading ? 'Cargando...' : 'Buscar'}
      </button>

      <pre>{datos ? JSON.stringify(datos, null, 2) : 'No hay datos'}</pre>
    </div>
  );
}